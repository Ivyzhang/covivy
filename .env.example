DATABASE_URL=postgresql+psycopg://app:app@postgres:5432/app
STORAGE_ROOT=/app/storage
PUBLIC_BASE_URL=https://your-tunnel.example
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY_PATH=/run/secrets/github-app-private-key.pem
GITHUB_WEBHOOK_SECRET=change-me
UPLOAD_TOKEN_PEPPER=change-me
ADMIN_TOKEN=change-me
GITHUB_COMMIT_STATUS_ENABLED=false
PATCH_COVERAGE_MINIMUM=0.8
